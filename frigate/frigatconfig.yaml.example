# Frigate Configuration Example
# Copy this to frigatconfig.yaml and fill in with your actual values

mqtt:
  host: YOUR_MQTT_SERVER_IP  # Your MQTT broker IP
  port: 1883

detectors:
  coral:
    type: edgetpu
    device: pci

cameras:
  example_camera:
    ffmpeg:
      inputs:
        - path: rtsp://USERNAME:PASSWORD@192.168.X.X/path/to/stream
          roles:
            - record
        - path: rtsp://USERNAME:PASSWORD@192.168.X.X/path/to/stream
          roles:
            - detect
      output_args:
        record:
          - -f segment -segment_time 60 -segment_format mp4 -reset_timestamps 1 -strftime 1 -c copy
      hwaccel_args:
        - -hwaccel
        - vaapi
        - -hwaccel_device
        - /dev/dri/renderD128
        - -hwaccel_output_format
        - yuv420p
    detect:
      width: 640
      height: 360
      fps: 20
    objects:
      track:
        - person
        - car
    record:
      enabled: true
      events:
        pre_capture: 5
        post_capture: 5
        objects:
          - person
          - car
